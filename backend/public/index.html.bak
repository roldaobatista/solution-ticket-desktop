              <span className="text-sm font-medium text-slate-700">Dias Restantes</span>
              <span className="text-lg font-bold text-primary-700">{licenca.diasRestantes}</span>
            </div>
            <div className="mt-4"><label className="block text-sm font-medium text-slate-700 mb-2">Chave de Ativacao</label><div className="flex gap-2"><input type="text" placeholder="XXXX-XXXX-XXXX-XXXX" className="flex-1 px-3 py-2 border border-slate-200 rounded-lg font-mono text-sm" /><button className="btn-primary text-white px-4 py-2 rounded-lg text-sm font-medium">Ativar</button></div></div>
          </div>
        </div>
      );
    }

    // ============================================================
    // CONFIGURACOES PAGE
    // ============================================================
    function ConfiguracoesPage() {
      return (
        <div className="p-6 fade-in max-w-2xl mx-auto">
          <h1 className="text-2xl font-bold text-slate-900 mb-6">Configuracoes</h1>
          <div className="bg-white rounded-xl border border-slate-100 p-6 space-y-6">
            <div><h3 className="text-sm font-semibold text-slate-800 mb-3">Dados da Empresa</h3><div className="grid grid-cols-2 gap-4"><div><label className="block text-xs text-slate-500 mb-1">Nome Empresarial</label><input type="text" className="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm" /></div><div><label className="block text-xs text-slate-500 mb-1">CNPJ</label><input type="text" className="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm" /></div></div></div>
            <div><h3 className="text-sm font-semibold text-slate-800 mb-3">Impressao</h3><div className="space-y-2"><label className="flex items-center gap-2"><input type="checkbox" className="rounded" defaultChecked /><span className="text-sm text-slate-600">Preview antes de imprimir</span></label><label className="flex items-center gap-2"><input type="checkbox" className="rounded" /><span className="text-sm text-slate-600">Manter preview aberto</span></label></div></div>
            <div><h3 className="text-sm font-semibold text-slate-800 mb-3">Pesagem</h3><div className="space-y-2"><label className="flex items-center gap-2"><input type="checkbox" className="rounded" defaultChecked /><span className="text-sm text-slate-600">Modo manual habilitado</span></label><label className="flex items-center gap-2"><input type="checkbox" className="rounded" defaultChecked /><span className="text-sm text-slate-600">Manter tara cadastrada</span></label></div></div>
            <div className="flex justify-end"><button className="btn-primary text-white px-6 py-2.5 rounded-lg font-semibold">Salvar Configuracoes</button></div>
          </div>
        </div>
      );
    }

    // ============================================================
    // MAIN APP
    // ============================================================
    function App() {
      const [user, setUser] = useState(() => {
        const saved = localStorage.getItem('user');
        return saved ? JSON.parse(saved) : null;
      });

      if (!user) {
        return <LoginPage onLogin={(u) => { setUser(u); localStorage.setItem('user', JSON.stringify(u)); }} />;
      }

      return (
        <StoreProvider>
          <AppInner initialUser={user} />
        </StoreProvider>
      );
    }

    function AppInner({ initialUser }) {
      const { activePage, setUser, sidebarOpen } = useStore();
      const pageMap = {
        dashboard: DashboardPage, pesagem: PesagemPage, tickets: TicketsPage,
        cadastros: CadastrosPage, balancas: BalancasPage, tabelaUmidade: TabelaUmidadePage,
        fila: FilaPage, auditoria: AuditoriaPage, romaneios: RomaneiosPage,
        faturas: FaturasPage, relatorios: RelatoriosPage, licenca: LicencaPage,
        configuracoes: ConfiguracoesPage,
      };
      const Page = pageMap[activePage] || DashboardPage;

      return (
        <div className="flex min-h-screen bg-slate-50">
          <Sidebar />
          <div className={`flex-1 flex flex-col min-h-screen transition-all duration-300 ${sidebarOpen ? 'max-w-[calc(100vw-16rem)]' : 'max-w-[calc(100vw-4rem)]'}`}>
            <header className="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 sticky top-0 z-10">
              <h2 className="text-lg font-semibold text-slate-800">{activePage.charAt(0).toUpperCase() + activePage.slice(1)}</h2>
              <div className="flex items-center gap-4">
                <div className="flex items-center gap-2">
                  <div className="w-8 h-8 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white text-xs font-bold">{initialUser.nome?.[0] || 'U'}</div>
                  <span className="text-sm text-slate-600">{initialUser.nome}</span>
                </div>
                <button onClick={() => { localStorage.removeItem('token'); localStorage.removeItem('user'); setUser(null); window.location.reload(); }} className="text-xs text-slate-400 hover:text-red-500">Sair</button>
              </div>
            </header>
            <main className="flex-1 overflow-auto"><Page /></main>
          </div>
          <Toast toast={useStore().toast} />
        </div>
      );
    }

    // ============================================================
    // MOUNT
    // ============================================================
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
