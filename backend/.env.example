# Copie este arquivo para `.env` e ajuste os valores.
# NUNCA commitar `.env`. Em produção, gere segredos novos e únicos.

# Banco de dados (SQLite local em desktop, Postgres em ambiente compartilhado)
DATABASE_URL=file:./data/solution-ticket.db

# Segredo JWT — OBRIGATÓRIO. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Mínimo 32 bytes de entropia. Sem fallback no código — backend não sobe se ausente.
JWT_SECRET=
JWT_EXPIRATION=24h

# Servidor
PORT=3001
NODE_ENV=development

# Senha inicial dos usuários criados pelo seed (admin/operador/supervisor).
# Operador será obrigado a trocar no primeiro login.
SEED_DEFAULT_PASSWORD=
