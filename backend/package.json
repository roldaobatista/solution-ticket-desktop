{
  "name": "@solution-ticket/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema=src/prisma/schema.prisma",
    "db:migrate:reset": "prisma migrate reset --schema=src/prisma/schema.prisma",
    "db:seed": "ts-node src/prisma/seed.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "statements": 22,
        "branches": 27,
        "functions": 19,
        "lines": 22
      }
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "@brazilian-utils/brazilian-utils": "^2.3.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^6",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^8",
    "@serialport/parser-readline": "^13.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4",
    "fast-xml-parser": "^4.5.6",
    "helmet": "^7",
    "jsonwebtoken": "^9.0.2",
    "modbus-serial": "^8.0.25",
    "multer": "^2.1.1",
    "nestjs-pino": "^4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "pino-pretty": "^11",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "serialport": "^13.0.0",
    "uuid": "^9.0.1"
  },
  "prisma": {
    "seed": "ts-node src/prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
