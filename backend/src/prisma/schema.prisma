generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

// ============================================================
// TENANT & EMPRESA
// ============================================================

model Tenant {
  id           String   @id @default(uuid()) @map("id")
  nome         String   @map("nome")
  documento    String?  @map("documento")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresas Empresa[]
  perfis   Perfil[]
  usuarios Usuario[]

  @@map("tenant")
}

model Empresa {
  id                 String   @id @default(uuid()) @map("id")
  tenantId           String   @map("tenant_id")
  nomeEmpresarial    String   @map("nome_empresarial")
  nomeFantasia       String?  @map("nome_fantasia")
  // RD3: PJ usa CNPJ em documento; PF usa CPF; PRODUTOR_RURAL usa IE como
  // identificador fiscal principal (CPF opcional). Validacao por tipoPessoa.
  tipoPessoa         String   @default("PJ") @map("tipo_pessoa") // PJ | PF | PRODUTOR_RURAL
  documento          String   @map("documento")
  inscricaoEstadual  String?  @map("inscricao_estadual")
  inscricaoMunicipal String?  @map("inscricao_municipal")
  endereco           String?  @map("endereco")
  cidade             String?  @map("cidade")
  uf                 String?  @map("uf")
  telefone           String?  @map("telefone")
  email              String?  @map("email")
  site               String?  @map("site")
  logoPrincipal      String?  @map("logo_principal")
  logoRelatorios     String?  @map("logo_relatorios")
  ativo              Boolean  @default(true) @map("ativo")
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  tenant             Tenant                           @relation(fields: [tenantId], references: [id])
  unidades           Unidade[]
  balancas           Balanca[]
  veiculos           Veiculo[]
  motoristas         Motorista[]
  configuracoes      ConfiguracaoOperacionalUnidade[]
  regrasOperacionais MatrizRegraOperacional[]

  @@unique([tenantId, documento])
  @@index([tenantId])
  @@map("empresa")
}

model Unidade {
  id           String   @id @default(uuid()) @map("id")
  empresaId    String   @map("empresa_id")
  nome         String   @map("nome")
  endereco     String?  @map("endereco")
  cidade       String?  @map("cidade")
  uf           String?  @map("uf")
  telefone     String?  @map("telefone")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa            Empresa                          @relation(fields: [empresaId], references: [id])
  balancas           Balanca[]
  tickets            TicketPesagem[]
  configuracoes      ConfiguracaoOperacionalUnidade[]
  regrasOperacionais MatrizRegraOperacional[]
  licencas           LicencaInstalacao[]

  @@index([empresaId])
  @@map("unidade")
}

// ============================================================
// PERFIL & PERMISSAO & USUARIO
// ============================================================

model Perfil {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  nome         String   @map("nome")
  descricao    String?  @map("descricao")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  usuarios   UsuarioPerfil[]
  permissoes Permissao[]

  @@map("perfil")
}

model Permissao {
  id        String   @id @default(uuid()) @map("id")
  perfilId  String   @map("perfil_id")
  modulo    String   @map("modulo")
  acao      String   @map("acao")
  concedido Boolean  @default(true) @map("concedido")
  criadoEm  DateTime @default(now()) @map("criado_em")

  perfil Perfil @relation(fields: [perfilId], references: [id])

  @@map("permissao")
}

model UsuarioPerfil {
  id        String   @id @default(uuid()) @map("id")
  usuarioId String   @map("usuario_id")
  perfilId  String   @map("perfil_id")
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  perfil  Perfil  @relation(fields: [perfilId], references: [id])

  @@map("usuario_perfil")
}

model Usuario {
  id              String    @id @default(uuid()) @map("id")
  tenantId        String    @map("tenant_id")
  nome            String    @map("nome")
  email           String    @unique @map("email")
  senhaHash       String    @map("senha_hash")
  ativo           Boolean   @default(true) @map("ativo")
  ultimoAcesso    DateTime? @map("ultimo_acesso")
  tentativasLogin Int       @default(0) @map("tentativas_login")
  bloqueadoAte    DateTime? @map("bloqueado_ate")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  atualizadoEm    DateTime  @updatedAt @map("atualizado_em")

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  perfis    UsuarioPerfil[]
  passagens PassagemPesagem[]

  @@index([tenantId])
  @@map("usuario")
}

// ============================================================
// CADASTROS MESTRE
// ============================================================

model Cliente {
  id                 String   @id @default(uuid()) @map("id")
  tenantId           String   @map("tenant_id")
  razaoSocial        String   @map("razao_social")
  // RD3: ver Empresa. Produtor rural muito comum em balanca de cooperativa.
  tipoPessoa         String   @default("PJ") @map("tipo_pessoa") // PJ | PF | PRODUTOR_RURAL
  documento          String?  @map("documento")
  inscricaoEstadual  String?  @map("inscricao_estadual")
  inscricaoMunicipal String?  @map("inscricao_municipal")
  endereco           String?  @map("endereco")
  cidade             String?  @map("cidade")
  uf                 String?  @map("uf")
  telefone           String?  @map("telefone")
  email              String?  @map("email")
  codigoIntegracao   String?  @map("codigo_integracao")
  saldoFinanceiro    Decimal? @default(0) @map("saldo_financeiro")
  ativo              Boolean  @default(true) @map("ativo")
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  tabelasPrecoCliente TabelaPrecoProdutoCliente[]
  tickets             TicketPesagem[]
  romaneios           Romaneio[]
  faturas             Fatura[]

  @@index([tenantId])
  @@unique([tenantId, documento], name: "cliente_documento_unique")
  @@map("cliente")
}

model Transportadora {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  nome         String   @map("nome")
  documento    String?  @map("documento")
  contatos     String?  @map("contatos")
  observacoes  String?  @map("observacoes")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  veiculos   Veiculo[]
  motoristas Motorista[]
  tickets    TicketPesagem[]

  @@index([tenantId])
  @@map("transportadora")
}

model Motorista {
  id               String   @id @default(uuid()) @map("id")
  tenantId         String   @map("tenant_id")
  empresaId        String?  @map("empresa_id")
  nome             String   @map("nome")
  documento        String?  @map("documento")
  cnh              String?  @map("cnh")
  telefone         String?  @map("telefone")
  transportadoraId String?  @map("transportadora_id")
  ativo            Boolean  @default(true) @map("ativo")
  criadoEm         DateTime @default(now()) @map("criado_em")
  atualizadoEm     DateTime @updatedAt @map("atualizado_em")

  empresa        Empresa?        @relation(fields: [empresaId], references: [id])
  transportadora Transportadora? @relation(fields: [transportadoraId], references: [id])
  tickets        TicketPesagem[]

  @@index([tenantId])
  @@index([empresaId])
  @@index([transportadoraId])
  @@map("motorista")
}

model Produto {
  id                String   @id @default(uuid()) @map("id")
  tenantId          String   @map("tenant_id")
  descricao         String   @map("descricao")
  codigoInterno     String?  @map("codigo_interno")
  unidade           String   @map("unidade")
  densidade         Decimal? @map("densidade")
  tipoOperacao      String?  @map("tipo_operacao")
  permiteFracionado Boolean  @default(false) @map("permite_fracionado")
  armazemPadraoId   String?  @map("armazem_padrao_id")
  ativo             Boolean  @default(true) @map("ativo")
  criadoEm          DateTime @default(now()) @map("criado_em")
  atualizadoEm      DateTime @updatedAt @map("atualizado_em")

  tickets             TicketPesagem[]
  tabelasUmidade      TabelaUmidade[]
  tabelasPreco        TabelaPrecoProduto[]
  tabelasPrecoCliente TabelaPrecoProdutoCliente[]
  tabelasFrete        TabelaFrete[]

  @@index([tenantId])
  @@map("produto")
}

model Veiculo {
  id               String   @id @default(uuid()) @map("id")
  tenantId         String   @map("tenant_id")
  empresaId        String?  @map("empresa_id")
  placa            String   @map("placa")
  transportadoraId String?  @map("transportadora_id")
  taraCadastrada   Decimal? @map("tara_cadastrada")
  observacoes      String?  @map("observacoes")
  ativo            Boolean  @default(true) @map("ativo")
  criadoEm         DateTime @default(now()) @map("criado_em")
  atualizadoEm     DateTime @updatedAt @map("atualizado_em")

  empresa        Empresa?        @relation(fields: [empresaId], references: [id])
  transportadora Transportadora? @relation(fields: [transportadoraId], references: [id])
  tickets        TicketPesagem[]

  @@unique([tenantId, placa])
  @@index([empresaId])
  @@index([transportadoraId])
  @@map("veiculo")
}

model Destino {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  descricao    String   @map("descricao")
  clienteId    String?  @map("cliente_id")
  endereco     String?  @map("endereco")
  cidade       String?  @map("cidade")
  uf           String?  @map("uf")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tickets      TicketPesagem[]
  tabelasFrete TabelaFrete[]

  @@map("destino")
}

model Origem {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  descricao    String   @map("descricao")
  clienteId    String?  @map("cliente_id")
  endereco     String?  @map("endereco")
  cidade       String?  @map("cidade")
  uf           String?  @map("uf")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tickets TicketPesagem[]

  @@map("origem")
}

model Armazem {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  descricao    String   @map("descricao")
  localizacao  String?  @map("localizacao")
  capacidadeKg Decimal? @map("capacidade_kg")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  tickets TicketPesagem[]

  @@map("armazem")
}

model IndicadorPesagem {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  descricao    String   @map("descricao")
  cor          String?  @map("cor")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  // Identificação do modelo (S6.1)
  fabricante   String? @map("fabricante")
  modelo       String? @map("modelo")
  protocolo    String  @default("serial") @map("protocolo") // serial | tcp | modbus
  builtin      Boolean @default(false) @map("builtin") // seed presets — não-deletáveis na UI
  exemploTrama String? @map("exemplo_trama")
  notas        String? @map("notas")

  // Parametros de hardware/protocolo de pesagem (extraidos do PesoLog)
  parserTipo    String? @map("parser_tipo") // generic | toledo | toledo-c | filizola | sics | modbus...
  baudrate      Int?    @map("baudrate")
  databits      Int?    @map("databits")
  stopbits      Int?    @map("stopbits")
  parity        String? @map("parity") // N | E | O (ou none/even/odd legado)
  flowControl   String? @map("flow_control") // NONE | XON_XOFF | RTS_CTS | DTR_DSR
  inicioPeso    Int?    @map("inicio_peso") // 1-indexed
  tamanhoPeso   Int?    @map("tamanho_peso")
  tamanhoString Int?    @map("tamanho_string")
  marcador      Int?    @map("marcador") // byte terminador (ex: 13 = CR)
  fator         Int?    @map("fator") // divisor do peso (1, 10, 100)
  invertePeso   Boolean @default(false) @map("inverte_peso")
  atraso        Int?    @map("atraso") // ms entre leituras

  tickets  TicketPesagem[]
  balancas Balanca[]

  @@unique([tenantId, descricao], name: "indicador_tenant_descricao_unique")
  @@index([tenantId])
  @@map("indicador_pesagem")
}

model FormaPagamento {
  id           String   @id @default(uuid()) @map("id")
  tenantId     String   @map("tenant_id")
  descricao    String   @map("descricao")
  tipo         String   @map("tipo")
  ativo        Boolean  @default(true) @map("ativo")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  pagamentos PagamentoFatura[]

  @@map("forma_pagamento")
}

// ============================================================
// BALANCA
// ============================================================

model Balanca {
  id               String  @id @default(uuid()) @map("id")
  empresaId        String  @map("empresa_id")
  unidadeId        String  @map("unidade_id")
  nome             String  @map("nome")
  marca            String? @map("marca")
  modelo           String? @map("modelo")
  protocolo        String  @default("serial") @map("protocolo")
  porta            String? @map("porta")
  baudRate         Int?    @map("baud_rate")
  enderecoIp       String? @map("endereco_ip")
  portaTcp         Int?    @map("porta_tcp")
  statusOnline     Boolean @default(true) @map("status_online")
  tipoEntradaSaida String? @map("tipo_entrada_saida")
  indicadorId      String? @map("indicador_id")
  ativo            Boolean @default(true) @map("ativo")

  // Override por equipamento (S6.2) — se preenchidos, sobrescrevem o indicador
  ovrDataBits      Int?     @map("ovr_data_bits")
  ovrParity        String?  @map("ovr_parity")
  ovrStopBits      Int?     @map("ovr_stop_bits")
  ovrFlowControl   String?  @map("ovr_flow_control")
  ovrInicioPeso    Int?     @map("ovr_inicio_peso")
  ovrTamanhoPeso   Int?     @map("ovr_tamanho_peso")
  ovrTamanhoString Int?     @map("ovr_tamanho_string")
  ovrMarcador      Int?     @map("ovr_marcador")
  ovrFator         Int?     @map("ovr_fator")
  ovrInvertePeso   Boolean? @map("ovr_inverte_peso")
  ovrAtraso        Int?     @map("ovr_atraso")
  ovrParserTipo    String?  @map("ovr_parser_tipo")

  // Telemetria de conexão (S6.6)
  ultimaConexao DateTime? @map("ultima_conexao")
  ultimaLeitura DateTime? @map("ultima_leitura")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa   Empresa           @relation(fields: [empresaId], references: [id])
  unidade   Unidade           @relation(fields: [unidadeId], references: [id])
  indicador IndicadorPesagem? @relation(fields: [indicadorId], references: [id])
  passagens PassagemPesagem[]

  @@index([empresaId, unidadeId])
  @@index([indicadorId])
  @@map("balanca")
}

// ============================================================
// CONFIGURACAO OPERACIONAL
// ============================================================

model ConfiguracaoOperacionalUnidade {
  id        String @id @default(uuid()) @map("id")
  empresaId String @map("empresa_id")
  unidadeId String @map("unidade_id")

  // Balanças padrão (S6.7) — equivalente ao [BALANCA] PADRAO_ENTRADA/SAIDA do PesoLog
  balancaPadraoEntrada String? @map("balanca_padrao_entrada")
  balancaPadraoSaida   String? @map("balanca_padrao_saida")

  // Feature flags
  pesagemComTara           Boolean @default(true) @map("pesagem_com_tara")
  pesagemEntrada           Boolean @default(true) @map("pesagem_entrada")
  pesagemSaida             Boolean @default(true) @map("pesagem_saida")
  financeiro               Boolean @default(false) @map("financeiro")
  cameras                  Boolean @default(false) @map("cameras")
  transportadoraHabilitada Boolean @default(true) @map("transportadora_habilitada")
  motoristaHabilitado      Boolean @default(true) @map("motorista_habilitado")
  armazemHabilitado        Boolean @default(false) @map("armazem_habilitado")
  manutencaoTicket         Boolean @default(true) @map("manutencao_ticket")
  conversaoUnidade         Boolean @default(false) @map("conversao_unidade")
  precoVenda               Boolean @default(false) @map("preco_venda")
  bilhetagem               Boolean @default(false) @map("bilhetagem")
  origemDestino            Boolean @default(false) @map("origem_destino")
  calculoFrete             Boolean @default(false) @map("calculo_frete")
  tabelaUmidade            Boolean @default(false) @map("tabela_umidade")
  descontos                Boolean @default(false) @map("descontos")
  emissaoRomaneio          Boolean @default(false) @map("emissao_romaneio")
  edicaoRomaneio           Boolean @default(false) @map("edicao_romaneio")
  habilitaBaixa            Boolean @default(false) @map("habilita_baixa")
  listaDocumentos          Boolean @default(false) @map("lista_documentos")

  // Configuracoes de impressao
  previewImpressao    Boolean @default(true) @map("preview_impressao")
  numeroCopias        Int     @default(1) @map("numero_copias")
  manterPreviewAberto Boolean @default(false) @map("manter_preview_aberto")
  modeloTicketPadrao  String? @map("modelo_ticket_padrao")
  logomarcaPadrao     String? @map("logomarca_padrao")
  logomarcaRelatorio  String? @map("logomarca_relatorio")

  // Campos adicionais
  labelAdicional1      String? @map("label_adicional_1")
  labelAdicional2      String? @map("label_adicional_2")
  observacaoHabilitada Boolean @default(true) @map("observacao_habilitada")
  rodapeTexto          String? @map("rodape_texto")
  manterTaraCadastrada Boolean @default(true) @map("manter_tara_cadastrada")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  unidade Unidade @relation(fields: [unidadeId], references: [id])

  @@unique([unidadeId], name: "configuracao_unidade_unique")
  @@map("configuracao_operacional_unidade")
}

model MatrizRegraOperacional {
  id                  String   @id @default(uuid()) @map("id")
  tenantId            String?  @map("tenant_id")
  empresaId           String?  @map("empresa_id")
  unidadeId           String?  @map("unidade_id")
  tipoOperacao        String?  @map("tipo_operacao")
  clienteId           String?  @map("cliente_id")
  produtoId           String?  @map("produto_id")
  campoAlvo           String   @map("campo_alvo")
  visivel             Boolean  @default(true) @map("visivel")
  obrigatorio         Boolean  @default(false) @map("obrigatorio")
  editavel            Boolean  @default(true) @map("editavel")
  valorPadrao         String?  @map("valor_padrao")
  ordemExibicao       Int?     @map("ordem_exibicao")
  prioridadeResolucao Int      @default(0) @map("prioridade_resolucao")
  criadoEm            DateTime @default(now()) @map("criado_em")
  atualizadoEm        DateTime @updatedAt @map("atualizado_em")

  empresa Empresa? @relation(fields: [empresaId], references: [id])
  unidade Unidade? @relation(fields: [unidadeId], references: [id])

  @@map("matriz_regra_operacional")
}

// ============================================================
// TICKET DE PESAGEM
// ============================================================

model TicketPesagem {
  id                       String @id @default(uuid()) @map("id")
  numero                   String @map("numero")
  unidadeId                String @map("unidade_id")
  tenantId                 String @map("tenant_id")
  statusOperacional        String @map("status_operacional")
  statusComercial          String @default("NAO_ROMANEADO") @map("status_comercial")
  fluxoPesagem             String @map("fluxo_pesagem")
  totalPassagensPrevistas  Int    @default(2) @map("total_passagens_previstas")
  totalPassagensRealizadas Int    @default(0) @map("total_passagens_realizadas")

  // Entidades relacionadas
  clienteId          String  @map("cliente_id")
  transportadoraId   String? @map("transportadora_id")
  motoristaId        String? @map("motorista_id")
  veiculoId          String? @map("veiculo_id")
  veiculoPlaca       String? @map("veiculo_placa")
  produtoId          String  @map("produto_id")
  origemId           String? @map("origem_id")
  destinoId          String? @map("destino_id")
  armazemId          String? @map("armazem_id")
  indicadorPesagemId String? @map("indicador_pesagem_id")

  // Documentos e nota
  notaFiscal String?  @map("nota_fiscal")
  pesoNf     Decimal? @map("peso_nf")

  // Peso apurado
  pesoBrutoApurado       Decimal? @map("peso_bruto_apurado")
  pesoTaraApurada        Decimal? @map("peso_tara_apurada")
  pesoLiquidoSemDesconto Decimal? @map("peso_liquido_sem_desconto")
  totalDescontos         Decimal? @default(0) @map("total_descontos")
  pesoLiquidoFinal       Decimal? @map("peso_liquido_final")

  // Tara referenciada
  taraCadastradaSnapshot Decimal? @map("tara_cadastrada_snapshot")
  taraReferenciaTipo     String?  @map("tara_referencia_tipo")

  // Snapshot comercial
  snapshotComercialVersao Int?     @map("snapshot_comercial_versao")
  modoComercial           String   @default("DESABILITADO") @map("modo_comercial")
  valorUnitario           Decimal? @map("valor_unitario")
  valorTotal              Decimal? @map("valor_total")

  // Datas
  primeiraPassagemEm DateTime? @map("primeira_passagem_em")
  ultimaPassagemEm   DateTime? @map("ultima_passagem_em")
  abertoEm           DateTime? @map("aberto_em")
  fechadoEm          DateTime? @map("fechado_em")
  canceladoEm        DateTime? @map("cancelado_em")
  motivoCancelamento String?   @map("motivo_cancelamento")

  // Campos adicionais
  observacao              String? @map("observacao")
  campo1                  String? @map("campo_1")
  campo2                  String? @map("campo_2")
  payloadCamposAdicionais String? @map("payload_campos_adicionais")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  unidade            Unidade                   @relation(fields: [unidadeId], references: [id])
  cliente            Cliente                   @relation(fields: [clienteId], references: [id])
  transportadora     Transportadora?           @relation(fields: [transportadoraId], references: [id])
  motorista          Motorista?                @relation(fields: [motoristaId], references: [id])
  veiculo            Veiculo?                  @relation(fields: [veiculoId], references: [id])
  produto            Produto                   @relation(fields: [produtoId], references: [id])
  origem             Origem?                   @relation(fields: [origemId], references: [id])
  destino            Destino?                  @relation(fields: [destinoId], references: [id])
  armazem            Armazem?                  @relation(fields: [armazemId], references: [id])
  indicadorPesagem   IndicadorPesagem?         @relation(fields: [indicadorPesagemId], references: [id])
  passagens          PassagemPesagem[]
  descontos          DescontoPesagem[]
  documentos         DocumentoPesagem[]
  snapshotsComercial SnapshotComercialTicket[]
  romaneios          ItemRomaneio[]

  @@unique([unidadeId, numero], name: "ticket_unidade_numero_unique")
  @@index([tenantId])
  @@index([unidadeId])
  @@index([clienteId])
  @@index([veiculoId])
  @@index([criadoEm])
  @@index([statusOperacional])
  @@index([tenantId, clienteId, criadoEm])
  @@index([tenantId, statusComercial, criadoEm])
  @@map("ticket_pesagem")
}

model PassagemPesagem {
  id                 String    @id @default(uuid()) @map("id")
  ticketId           String    @map("ticket_id")
  sequencia          Int       @map("sequencia")
  tipoPassagem       String    @map("tipo_passagem")
  direcaoOperacional String    @map("direcao_operacional")
  papelCalculo       String    @map("papel_calculo")
  condicaoVeiculo    String    @default("NAO_INFORMADO") @map("condicao_veiculo")
  statusPassagem     String    @map("status_passagem")
  pesoCapturado      Decimal   @map("peso_capturado")
  dataHora           DateTime  @map("data_hora")
  capturedAtLocal    DateTime? @map("captured_at_local")
  receivedAtBackend  DateTime  @default(now()) @map("received_at_backend")

  // Balanca e operador
  balancaId             String   @map("balanca_id")
  usuarioId             String   @map("usuario_id")
  origemLeitura         String   @map("origem_leitura")
  indicadorEstabilidade Decimal? @map("indicador_estabilidade")

  // Sincronizacao
  sequenceNoDispositivo Int?    @map("sequence_no_dispositivo")
  eventIdOrigem         String? @map("event_id_origem")
  observacao            String? @map("observacao")
  motivoInvalidacao     String? @map("motivo_invalidacao")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  ticket  TicketPesagem @relation(fields: [ticketId], references: [id])
  balanca Balanca       @relation(fields: [balancaId], references: [id])
  usuario Usuario       @relation(fields: [usuarioId], references: [id])

  @@unique([ticketId, sequencia], name: "passagem_ticket_sequencia_unique")
  @@index([ticketId])
  @@index([balancaId])
  @@index([usuarioId])
  @@index([dataHora])
  @@map("passagem_pesagem")
}

model DescontoPesagem {
