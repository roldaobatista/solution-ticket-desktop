  dispositivo String    @map("dispositivo") // SEMAFORO | CANCELA
  comando     String    @map("comando") // VERDE | VERMELHO | ABRIR | FECHAR
  status      String    @default("PENDENTE") @map("status") // PENDENTE | EXECUTADO | FALHA
  motivo      String?   @map("motivo")
  ticketId    String?   @map("ticket_id")
  usuarioId   String?   @map("usuario_id")
  criadoEm    DateTime  @default(now()) @map("criado_em")
  executadoEm DateTime? @map("executado_em")

  @@index([unidadeId])
  @@index([dispositivo])
  @@map("evento_automacao")
}

// ============================================================
// ASSINATURA DIGITAL (S5.1 - paridade PesoLog)
// ============================================================

model AssinaturaTicket {
  id            String   @id @default(uuid())
  ticketId      String   @unique @map("ticket_id")
  papel         String   @map("papel") // OPERADOR | MOTORISTA | RESPONSAVEL
  nome          String?  @map("nome")
  documento     String?  @map("documento")
  assinaturaPng String   @map("assinatura_png") // base64 PNG
  capturadoEm   DateTime @default(now()) @map("capturado_em")

  @@index([ticketId])
  @@map("assinatura_ticket")
}
