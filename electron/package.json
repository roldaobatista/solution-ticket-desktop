{
  "name": "@solution-ticket/desktop-shell",
  "version": "1.0.0",
  "description": "Solution Ticket desktop wrapper (Electron)",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "start": "electron .",
    "build": "echo 'Build handled by electron-builder in dist script'",
    "rebuild:native": "node rebuild-native.js",
    "dist": "node prep-cache.js && cross-env REBUILD_STRICT=true node rebuild-native.js && electron-builder"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5",
    "electron-updater": "^6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.solutionticket.desktop",
    "productName": "Solution Ticket",
    "directories": {
      "output": "../release"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.{node,dll}"
    ],
    "files": [
      "main.js",
      "updater.js",
      "preload.js",
      "splash.html",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.env.*",
          "!**/*.md",
          "!**/*.markdown",
          "!**/*.ts",
          "!**/*.d.ts",
          "!**/*.tsx",
          "!**/*.map",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/__mocks__/**",
          "!**/spec/**",
          "!**/*.spec.js",
          "!**/*.test.js",
          "!**/example/**",
          "!**/examples/**",
          "!**/docs/**",
          "!**/doc/**",
          "!**/.bin/**",
          "!**/.github/**",
          "!**/.vscode/**",
          "!**/.idea/**",
          "!**/.gitattributes",
          "!**/.gitignore",
          "!**/.editorconfig",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/.babelrc*",
          "!**/.npmignore",
          "!**/.travis.yml",
          "!**/.appveyor.yml",
          "!**/CHANGELOG*",
          "!**/HISTORY*",
          "!**/AUTHORS*",
          "!**/CONTRIBUTORS*",
          "!**/LICENSE.txt",
          "!**/license.txt",
          "!**/tsconfig*.json",
          "!**/jest.config*",
          "!**/karma.conf.js",
          "!**/rollup.config*",
          "!**/webpack.config*",
          "!**/Makefile",
          "!**/*.coffee",
          "!**/*.flow",
          "!**/*.h",
          "!**/*.cc",
          "!**/*.cpp",
          "!**/*.gyp",
          "!**/*.gypi",
          "!**/build/Release/obj/**",
          "!**/build/Release/obj.target/**",
          "!**/node_modules/.cache/**",
          "!**/node_modules/typescript/**",
          "!**/node_modules/@types/**",
          "!**/node_modules/.prisma/client/libquery_engine-darwin*",
          "!**/node_modules/.prisma/client/libquery_engine-debian-*",
          "!**/node_modules/.prisma/client/libquery_engine-linux*",
          "!**/node_modules/.prisma/client/libquery_engine-rhel-*",
          "!**/node_modules/@prisma/engines/libquery_engine-darwin*",
          "!**/node_modules/@prisma/engines/libquery_engine-debian-*",
          "!**/node_modules/@prisma/engines/libquery_engine-linux*",
          "!**/node_modules/@prisma/engines/libquery_engine-rhel-*",
          "!**/node_modules/@prisma/engines/migration-engine-darwin*",
          "!**/node_modules/@prisma/engines/migration-engine-debian*",
          "!**/node_modules/@prisma/engines/migration-engine-linux*",
          "!**/node_modules/@prisma/engines/migration-engine-rhel*",
          "!**/node_modules/@prisma/engines/schema-engine-darwin*",
          "!**/node_modules/@prisma/engines/schema-engine-debian*",
          "!**/node_modules/@prisma/engines/schema-engine-linux*",
          "!**/node_modules/@prisma/engines/schema-engine-rhel*",
          "!**/@serialport/bindings-cpp/prebuilds/!(win32-x64)/**",
          "!**/prebuilds/darwin-*/**",
          "!**/prebuilds/linux-*/**",
          "!**/prebuilds/android-*/**",
          "!**/prebuilds/ios-*/**",
          "!**/@swc/core-darwin-*/**",
          "!**/@swc/core-linux-*/**",
          "!**/@swc/core-android-*/**",
          "!**/@swc/core-freebsd-*/**",
          "!**/@swc/core-win32-arm64-msvc/**",
          "!**/@swc/core-win32-ia32-msvc/**",
          "!**/@next/swc-darwin-*/**",
          "!**/@next/swc-linux-*/**",
          "!**/@next/swc-win32-arm64-*/**",
          "!**/@next/swc-win32-ia32-*/**",
          "!**/@parcel/watcher-darwin-*/**",
          "!**/@parcel/watcher-linux-*/**",
          "!**/esbuild-darwin*/**",
          "!**/esbuild-linux*/**",
          "!**/@esbuild/darwin-*/**",
          "!**/@esbuild/linux-*/**",
          "!**/@esbuild/android-*/**",
          "!**/@esbuild/freebsd-*/**",
          "!**/@esbuild/openbsd-*/**",
          "!**/@esbuild/sunos-*/**",
          "!**/@esbuild/win32-arm64/**",
          "!**/@esbuild/win32-ia32/**",
          "!**/node_modules/@nestjs/cli/**",
          "!**/node_modules/@nestjs/schematics/**",
          "!**/node_modules/@nestjs/testing/**",
          "!**/node_modules/@swc/cli/**",
          "!**/node_modules/jest/**",
          "!**/node_modules/jest-*/**",
          "!**/node_modules/ts-jest/**",
          "!**/node_modules/eslint/**",
          "!**/node_modules/eslint-*/**",
          "!**/node_modules/@typescript-eslint/**",
          "!**/node_modules/prettier/**",
          "!**/node_modules/supertest/**",
          "!**/node_modules/ts-node/**"
        ]
      },
      {
        "from": "../backend/src/prisma",
        "to": "backend/src/prisma"
      },
      {
        "from": "../frontend/.next",
        "to": "frontend/.next",
        "filter": [
          "**/*",
          "!cache/**",
          "!trace",
          "!**/*.map"
        ]
      },
      {
        "from": "../frontend/package.json",
        "to": "frontend/package.json"
      },
      {
        "from": "../frontend/next.config.js",
        "to": "frontend/next.config.js"
      },
      {
        "from": "../frontend/node_modules",
        "to": "frontend/node_modules",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.env.*",
          "!**/*.md",
          "!**/*.markdown",
          "!**/*.ts",
          "!**/*.d.ts",
          "!**/*.tsx",
          "!**/*.map",
          "!**/test/**",
          "!**/tests/**",
          "!**/__tests__/**",
          "!**/__mocks__/**",
          "!**/spec/**",
          "!**/*.spec.js",
          "!**/*.test.js",
          "!**/example/**",
          "!**/examples/**",
          "!**/docs/**",
          "!**/doc/**",
          "!**/.bin/**",
          "!**/.github/**",
          "!**/.vscode/**",
          "!**/.idea/**",
          "!**/.gitattributes",
          "!**/.gitignore",
          "!**/.editorconfig",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/.babelrc*",
          "!**/.npmignore",
          "!**/.travis.yml",
          "!**/CHANGELOG*",
          "!**/HISTORY*",
          "!**/AUTHORS*",
          "!**/CONTRIBUTORS*",
          "!**/LICENSE.txt",
          "!**/license.txt",
          "!**/tsconfig*.json",
          "!**/jest.config*",
          "!**/karma.conf.js",
          "!**/rollup.config*",
          "!**/Makefile",
          "!**/*.coffee",
          "!**/*.flow",
          "!**/*.h",
          "!**/*.cc",
          "!**/*.cpp",
          "!**/node_modules/.cache/**",
          "!**/node_modules/typescript/**",
          "!**/node_modules/@types/**",
          "!**/@next/swc-darwin-*/**",
          "!**/@next/swc-linux-*/**",
          "!**/@next/swc-win32-arm64-*/**",
          "!**/@next/swc-win32-ia32-*/**",
          "!**/@swc/core-darwin-*/**",
          "!**/@swc/core-linux-*/**",
          "!**/@swc/core-android-*/**",
          "!**/@swc/core-freebsd-*/**",
          "!**/@swc/core-win32-arm64-msvc/**",
          "!**/@swc/core-win32-ia32-msvc/**",
          "!**/@parcel/watcher-darwin-*/**",
          "!**/@parcel/watcher-linux-*/**",
          "!**/esbuild-darwin*/**",
          "!**/esbuild-linux*/**",
          "!**/@esbuild/darwin-*/**",
          "!**/@esbuild/linux-*/**",
          "!**/@esbuild/android-*/**",
          "!**/@esbuild/freebsd-*/**",
          "!**/@esbuild/openbsd-*/**",
          "!**/@esbuild/sunos-*/**",
          "!**/@esbuild/win32-arm64/**",
          "!**/@esbuild/win32-ia32/**",
          "!**/lightningcss-darwin-*/**",
          "!**/lightningcss-linux-*/**",
          "!**/lightningcss-freebsd-*/**",
          "!**/lightningcss-win32-arm64-*/**"
        ]
      },
      {
        "from": "../resources/drivers/CH340",
        "to": "drivers/CH340"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "Solution-Ticket-Setup-${version}.exe",
      "publisherName": "Solution Ticket",
      "signAndEditExecutable": true,
      "sign": "sign.js"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "roldaobatista",
        "repo": "solution-ticket-desktop",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Solution Ticket",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
